{
  "name": "clothing-store-backend",
  "version": "1.0.0",
  "description": "REST API for Clothing Store application",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "db:migrate": "node scripts/run-database-files.js migrate",
